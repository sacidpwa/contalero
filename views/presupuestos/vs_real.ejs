<%- include('../partials/header', { title, path, mes, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Presupuesto vs Real</h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">Comparativa de presupuesto contra ejecución real</p>
  </div>
  <form class="d-flex align-items-center gap-2" method="GET" action="/presupuestos/vs-real">
    <div>
      <select class="form-select form-select-sm" name="mes" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% var meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre']; %>
        <% for (var i = 1; i <= 12; i++) { %>
          <option value="<%= i %>" <%= mes == i ? 'selected' : '' %>><%= meses[i-1] %></option>
        <% } %>
      </select>
    </div>
    <div>
      <select class="form-select form-select-sm" name="ejercicio" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var a = 2020; a <= 2035; a++) { %>
          <option value="<%= a %>" <%= ejercicio == a ? 'selected' : '' %>><%= a %></option>
        <% } %>
      </select>
    </div>
    <button type="submit" class="btn btn-sm btn-period"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
  </form>
</div>

<div class="card card-dashboard">
  <div class="card-body">
    <div class="section-title"><i class="bi bi-bar-chart-line"></i>Comparativa <span class="text-muted fw-normal" style="font-size:.85rem;">— <%= ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'][mes - 1] %> <%= ejercicio %></span></div>
    <div class="table-responsive">
      <table class="table table-sm table-summary mb-0">
        <thead>
          <tr>
            <th>Cuenta</th>
            <th class="text-end">Presupuesto</th>
            <th class="text-end">Real</th>
            <th class="text-end">Variación</th>
            <th class="text-end">% Cumplimiento</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof datos !== 'undefined' && datos.length) { %>
            <% datos.forEach(function(d) { %>
              <% var variacion = Number(d.presupuesto) - Number(d.real); %>
              <% var pct = Number(d.presupuesto) > 0 ? (Number(d.real) / Number(d.presupuesto)) * 100 : 0; %>
              <tr>
                <td><span class="fw-semibold"><%= d.codigo %></span><br><span class="text-muted" style="font-size:.8rem;"><%= d.cuenta_nombre %></span></td>
                <td class="text-end fw-semibold">$<%= Number(d.presupuesto).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
                <td class="text-end fw-semibold">$<%= Number(d.real).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
                <td class="text-end fw-semibold" style="color:<%= variacion < 0 ? '#dc2626' : '#16a34a' %>;">
                  $<%= Number(variacion).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %>
                </td>
                <td class="text-end fw-semibold" style="color:<%= pct < 0 ? '#dc2626' : '#0f172a' %>;">
                  <%= Number(pct).toLocaleString('es-MX', {minimumFractionDigits:1,maximumFractionDigits:1}) %>%</td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-3" style="font-size:.9rem;">No hay datos para el período seleccionado</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
