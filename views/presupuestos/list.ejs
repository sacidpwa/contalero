<%- include('../partials/header', { title, path, mes, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Presupuestos</h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">Administración de presupuestos por cuenta y período</p>
  </div>
  <a href="/presupuestos/vs-real?mes=<%= mes %>&ejercicio=<%= ejercicio %>" class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.85rem;">
    <i class="bi bi-bar-chart-line me-1"></i>vs Real
  </a>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-5">
    <div class="card card-dashboard">
      <div class="card-body">
        <div class="section-title"><i class="bi bi-plus-circle"></i><%= typeof presupuestoEditar !== 'undefined' && presupuestoEditar ? 'Editar Presupuesto' : 'Nuevo Presupuesto' %></div>
        <form method="POST" action="/presupuestos/guardar">
          <% if (typeof presupuestoEditar !== 'undefined' && presupuestoEditar) { %>
            <input type="hidden" name="id" value="<%= presupuestoEditar.id %>">
          <% } %>
          <div class="mb-3">
            <label class="form-label form-label-sm text-muted" style="font-size:.85rem;font-weight:500;">Cuenta</label>
            <select class="form-select form-select-sm" name="cuenta_id" required style="border-radius:8px;border-color:#e2e8f0;font-size:.9rem;">
              <option value="">Seleccionar cuenta...</option>
              <% if (typeof cuentas !== 'undefined' && cuentas.length) { %>
                <% cuentas.forEach(function(c) { %>
                  <option value="<%= c.id %>" <%= typeof presupuestoEditar !== 'undefined' && presupuestoEditar && presupuestoEditar.cuenta_id == c.id ? 'selected' : '' %>><%= c.codigo %> - <%= c.nombre %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="row g-2">
            <div class="col-4">
              <label class="form-label form-label-sm text-muted" style="font-size:.85rem;font-weight:500;">Mes</label>
              <select class="form-select form-select-sm" name="mes" required style="border-radius:8px;border-color:#e2e8f0;font-size:.9rem;">
                <% var meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre']; %>
                <% for (var i = 1; i <= 12; i++) { %>
                  <option value="<%= i %>" <%= (typeof presupuestoEditar !== 'undefined' && presupuestoEditar ? presupuestoEditar.mes : mes) == i ? 'selected' : '' %>><%= meses[i-1] %></option>
                <% } %>
              </select>
            </div>
            <div class="col-4">
              <label class="form-label form-label-sm text-muted" style="font-size:.85rem;font-weight:500;">Ejercicio</label>
              <select class="form-select form-select-sm" name="ejercicio" required style="border-radius:8px;border-color:#e2e8f0;font-size:.9rem;">
                <% for (var a = 2020; a <= 2035; a++) { %>
                  <option value="<%= a %>" <%= (typeof presupuestoEditar !== 'undefined' && presupuestoEditar ? presupuestoEditar.ejercicio : ejercicio) == a ? 'selected' : '' %>><%= a %></option>
                <% } %>
              </select>
            </div>
            <div class="col-4">
              <label class="form-label form-label-sm text-muted" style="font-size:.85rem;font-weight:500;">Monto</label>
              <input type="number" step="0.01" class="form-control form-control-sm" name="monto" required value="<%= typeof presupuestoEditar !== 'undefined' && presupuestoEditar ? Number(presupuestoEditar.monto).toFixed(2) : '' %>" style="border-radius:8px;border-color:#e2e8f0;font-size:.9rem;">
            </div>
          </div>
          <div class="mt-3">
            <button type="submit" class="btn btn-sm btn-primary" style="border-radius:8px;font-size:.85rem;">
              <i class="bi bi-check-lg me-1"></i><%= typeof presupuestoEditar !== 'undefined' && presupuestoEditar ? 'Actualizar' : 'Guardar' %>
            </button>
            <% if (typeof presupuestoEditar !== 'undefined' && presupuestoEditar) { %>
              <a href="/presupuestos" class="btn btn-sm btn-outline-secondary ms-2" style="border-radius:8px;font-size:.85rem;">
                <i class="bi bi-x-lg me-1"></i>Cancelar
              </a>
            <% } %>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="col-lg-7">
    <div class="card card-dashboard">
      <div class="card-body">
        <div class="section-title"><i class="bi bi-list"></i>Presupuestos Registrados</div>
        <div class="table-responsive">
          <table class="table table-sm table-summary mb-0">
            <thead>
              <tr>
                <th>Cuenta</th>
                <th>Mes</th>
                <th>Ejercicio</th>
                <th class="text-end">Presupuesto</th>
                <th class="text-center">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof presupuestos !== 'undefined' && presupuestos.length) { %>
                <% presupuestos.forEach(function(p) { %>
                  <tr>
                    <td><span class="fw-semibold"><%= p.codigo %></span><br><span class="text-muted" style="font-size:.8rem;"><%= p.cuenta_nombre %></span></td>
                    <td><%= ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'][p.mes - 1] %></td>
                    <td><%= p.ejercicio %></td>
                    <td class="text-end fw-semibold">$<%= Number(p.monto).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
                    <td class="text-center">
                      <a href="/presupuestos?editar=<%= p.id %>" class="btn btn-sm btn-outline-secondary" style="border-radius:6px;padding:.2rem .5rem;font-size:.8rem;" title="Editar">
                        <i class="bi bi-pencil"></i>
                      </a>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-3" style="font-size:.9rem;">No hay presupuestos registrados</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
