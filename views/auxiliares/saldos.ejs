<%- include('../partials/header', { title, path, mes, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Saldos de <%= auxiliar.nombre %></h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">Movimientos y saldo del auxiliar</p>
  </div>
  <a href="/auxiliares" class="btn btn-sm btn-period"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card mb-4" style="border:none;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-3">
        <div class="d-flex align-items-center gap-2">
          <span style="color:#64748b;font-size:.85rem;font-weight:500;">Código:</span>
          <span class="fw-bold" style="color:#2563eb;"><%= auxiliar.codigo %></span>
        </div>
      </div>
      <div class="col-md-3">
        <div class="d-flex align-items-center gap-2">
          <span style="color:#64748b;font-size:.85rem;font-weight:500;">Nombre:</span>
          <span class="fw-semibold" style="color:#0f172a;"><%= auxiliar.nombre %></span>
        </div>
      </div>
      <div class="col-md-3">
        <div class="d-flex align-items-center gap-2">
          <span style="color:#64748b;font-size:.85rem;font-weight:500;">RFC:</span>
          <span class="fw-semibold" style="font-family:monospace;"><%= auxiliar.rfc || '—' %></span>
        </div>
      </div>
      <div class="col-md-3">
        <div class="d-flex align-items-center gap-2">
          <span style="color:#64748b;font-size:.85rem;font-weight:500;">Tipo:</span>
          <span class="badge" style="background:<%= auxiliar.tipo === 'Cliente' ? '#dbeafe' : auxiliar.tipo === 'Proveedor' ? '#fef2f2' : '#f0fdf4' %>;color:<%= auxiliar.tipo === 'Cliente' ? '#1d4ed8' : auxiliar.tipo === 'Proveedor' ? '#dc2626' : '#16a34a' %>;font-size:.85rem;border-radius:6px;padding:.25rem .65rem;">
            <%= auxiliar.tipo %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card" style="border:none;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" style="font-size:.9rem;">
        <thead>
          <tr style="background:#1e293b;color:#f1f5f9;">
            <th class="ps-4 py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Fecha</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Póliza</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Cuenta</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Concepto</th>
            <th class="text-end py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Debe</th>
            <th class="text-end pe-4 py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Haber</th>
          </tr>
        </thead>
        <tbody>
          <% var totalDebe = 0, totalHaber = 0; %>
          <% if (typeof movimientos !== 'undefined' && movimientos.length > 0) { %>
            <% movimientos.forEach(function(m) { %>
              <% totalDebe += (m.debe || 0); totalHaber += (m.haber || 0); %>
              <tr style="border-bottom:1px solid #f1f5f9;">
                <td class="ps-4 py-2"><%= m.fecha %></td>
                <td class="py-2 fw-medium"><%= m.tipo_poliza %>-<%= m.numero %></td>
                <td class="py-2" style="color:#2563eb;"><%= m.cuenta_codigo %> — <%= m.cuenta_nombre %></td>
                <td class="py-2" style="max-width:250px;"><%= m.concepto || '—' %></td>
                <td class="text-end py-2"><%= m.debe ? '$' + Number(m.debe).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) : '—' %></td>
                <td class="text-end pe-4 py-2"><%= m.haber ? '$' + Number(m.haber).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) : '—' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-4 text-muted">No hay movimientos registrados para este auxiliar.</td>
            </tr>
          <% } %>
        </tbody>
        <tfoot>
          <tr style="background:#f8fafc;border-top:2px solid #e2e8f0;">
            <td class="ps-4 py-3 fw-bold" colspan="2" style="color:#0f172a;">TOTALES</td>
            <td class="py-3"></td>
            <td class="py-3"></td>
            <td class="text-end py-3 fw-bold" style="color:#0f172a;">$<%= Number(totalDebe).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            <td class="text-end pe-4 py-3 fw-bold" style="color:#0f172a;">$<%= Number(totalHaber).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
          </tr>
          <tr style="background:#f1f5f9;">
            <td class="ps-4 py-3 fw-bold" colspan="5" style="color:#0f172a;font-size:1rem;">SALDO</td>
            <td class="text-end pe-4 py-3 fw-bold" style="color:<%= (totalDebe - totalHaber) >= 0 ? '#0f172a' : '#dc2626' %>;font-size:1rem;">$<%= Number(totalDebe - totalHaber).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>