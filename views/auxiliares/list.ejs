<%- include('../partials/header', { title, path, mes, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Auxiliares (Terceros)</h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">Administración de proveedores, clientes y terceros</p>
  </div>
  <div class="d-flex gap-2">
    <form class="d-flex align-items-center gap-2" method="GET" action="/auxiliares">
      <div>
        <select class="form-select form-select-sm" name="tipo" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
          <option value="">Todos</option>
          <option value="Cliente" <%= tipo === 'Cliente' ? 'selected' : '' %>>Cliente</option>
          <option value="Proveedor" <%= tipo === 'Proveedor' ? 'selected' : '' %>>Proveedor</option>
          <option value="Ambos" <%= tipo === 'Ambos' ? 'selected' : '' %>>Ambos</option>
        </select>
      </div>
      <button type="submit" class="btn btn-sm btn-period"><i class="bi bi-funnel me-1"></i>Filtrar</button>
    </form>
    <a href="/auxiliares/nuevo" class="btn btn-sm" style="background:#2563eb;color:#fff;border-radius:8px;padding:.35rem .85rem;font-size:.85rem;font-weight:500;border:none;white-space:nowrap;">
      <i class="bi bi-plus-lg me-1"></i>Nuevo Auxiliar
    </a>
  </div>
</div>

<div class="card" style="border:none;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" style="font-size:.9rem;">
        <thead>
          <tr style="background:#1e293b;color:#f1f5f9;">
            <th class="ps-4 py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Código</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Nombre</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">RFC</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Tipo</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Teléfono</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Email</th>
            <th class="py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Activo</th>
            <th class="text-end pe-4 py-3" style="font-weight:500;font-size:.85rem;text-transform:uppercase;letter-spacing:.4px;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof auxiliares !== 'undefined' && auxiliares.length > 0) { %>
            <% auxiliares.forEach(function(a) { %>
              <tr style="border-bottom:1px solid #f1f5f9;">
                <td class="ps-4 py-2 fw-semibold" style="color:#2563eb;"><%= a.codigo %></td>
                <td class="py-2"><%= a.nombre %></td>
                <td class="py-2" style="font-family:monospace;font-size:.85rem;"><%= a.rfc || '—' %></td>
                <td class="py-2">
                  <span class="badge" style="background:<%= a.tipo === 'Cliente' ? '#dbeafe' : a.tipo === 'Proveedor' ? '#fef2f2' : '#f0fdf4' %>;color:<%= a.tipo === 'Cliente' ? '#1d4ed8' : a.tipo === 'Proveedor' ? '#dc2626' : '#16a34a' %>;font-size:.8rem;border-radius:6px;padding:.25rem .6rem;">
                    <%= a.tipo %>
                  </span>
                </td>
                <td class="py-2"><%= a.telefono || '—' %></td>
                <td class="py-2" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= a.email || '—' %></td>
                <td class="py-2">
                  <% if (a.activo) { %>
                    <span class="badge" style="background:#dcfce7;color:#16a34a;font-size:.8rem;border-radius:6px;padding:.25rem .6rem;"><i class="bi bi-check-circle"></i> Sí</span>
                  <% } else { %>
                    <span class="badge" style="background:#fef2f2;color:#dc2626;font-size:.8rem;border-radius:6px;padding:.25rem .6rem;"><i class="bi bi-x-circle"></i> No</span>
                  <% } %>
                </td>
                <td class="text-end pe-4 py-2">
                  <div class="d-flex justify-content-end gap-1">
                    <a href="/auxiliares/editar/<%= a.id %>" class="btn btn-sm" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;color:#475569;padding:.2rem .6rem;font-size:.8rem;" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/auxiliares/saldos/<%= a.id %>" class="btn btn-sm" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;color:#475569;padding:.2rem .6rem;font-size:.8rem;" title="Saldos">
                      <i class="bi bi-calculator"></i>
                    </a>
                    <a href="/auxiliares/eliminar/<%= a.id %>" class="btn btn-sm" style="background:#fef2f2;border:1px solid #fecaca;border-radius:6px;color:#dc2626;padding:.2rem .6rem;font-size:.8rem;" title="Eliminar" onclick="return confirm('¿Eliminar este auxiliar?')">
                      <i class="bi bi-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="text-center py-4 text-muted">No hay auxiliares registrados.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>