<%- include('../partials/header', { title, path }) %>

<div class="container-fluid px-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-book"></i> Catálogo de Cuentas</h4>
    <a href="/catalogo/nueva" class="btn btn-primary">
      <i class="bi bi-plus-lg"></i> Nueva Cuenta
    </a>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Código</th>
              <th>Nombre</th>
              <th class="text-center">Nivel</th>
              <th class="text-center">Naturaleza</th>
              <th class="text-center">Acepta Movimientos</th>
              <th class="text-center">Estado</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (cuentas && cuentas.length) { %>
              <% cuentas.forEach(function(c) { %>
                <tr>
                  <td class="font-monospace"><%= c.codigo %></td>
                  <td>
                    <span style="padding-left: <%= (c.nivel - 1) * 20 %>px; <%= c.nivel === 1 ? 'font-weight: 700;' : '' %>">
                      <% if (c.nivel === 1) { %><strong><%= c.nombre %></strong><% } else { %><%= c.nombre %><% } %>
                    </span>
                  </td>
                  <td class="text-center"><span class="badge bg-secondary"><%= c.nivel %></span></td>
                  <td class="text-center">
                    <% if (c.naturaleza === 'Deudora') { %>
                      <span class="badge bg-danger">Deudora</span>
                    <% } else { %>
                      <span class="badge bg-success">Acreedora</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <% if (c.acepta_movimientos) { %>
                      <span class="badge bg-success">Sí</span>
                    <% } else { %>
                      <span class="badge bg-secondary">No</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <% if (c.activo) { %>
                      <span class="badge bg-success">Activo</span>
                    <% } else { %>
                      <span class="badge bg-danger">Inactivo</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <a href="/catalogo/editar/<%= c.id %>" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/catalogo/eliminar/<%= c.id %>" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="return confirm('¿Eliminar la cuenta <%= c.codigo %> - <%= c.nombre %>?')">
                      <i class="bi bi-trash"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 8px;"></i>
                  No hay cuentas registradas.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
