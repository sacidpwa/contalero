<%- include('../partials/header', { title }) %>
<div class="container-fluid px-0">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="section-title mb-0"><i class="bi bi-upload"></i>Importar desde Aspel COI</h5>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i><%= error %></div>
  <% } %>

  <% if (resultado) { %>
    <div class="alert alert-success">
      <h6><i class="bi bi-check-circle me-2"></i>Importación completada</h6>
      <table class="table table-sm table-borderless mb-0" style="max-width:400px">
        <tr><td>Cuentas</td><td class="text-end fw-bold"><%= resultado.res.cuentas %></td></tr>
        <tr><td>Auxiliares</td><td class="text-end fw-bold"><%= resultado.res.auxiliares %></td></tr>
        <tr><td>Departamentos</td><td class="text-end fw-bold"><%= resultado.res.deptos %></td></tr>
        <tr><td>Pólizas (cabeceras)</td><td class="text-end fw-bold"><%= resultado.res.polizas %></td></tr>
        <tr><td>Detalles de póliza</td><td class="text-end fw-bold"><%= resultado.res.detalles %></td></tr>
        <tr><td>Saldo de cuentas</td><td class="text-end fw-bold"><%= resultado.res.saldos %></td></tr>
        <tr><td>Datos de empresa</td><td class="text-end fw-bold"><%= resultado.res.empresas %></td></tr>
        <tr><td>Años importados</td><td class="text-end fw-bold"><%= resultado.res.years.join(', ') %></td></tr>
      </table>
      <hr>
      <div style="max-height:200px;overflow-y:auto;font-size:.85rem">
        <% resultado.log.forEach(function(l) { %><div><%= l %></div><% }) %>
      </div>
      <a href="/dashboard" class="btn btn-primary mt-3"><i class="bi bi-speedometer2 me-1"></i>Ir al Dashboard</a>
    </div>
  <% } %>

  <div class="card card-dashboard">
    <div class="card-body">
      <p class="text-muted">Selecciona un archivo de respaldo <strong>.fdb</strong> de Aspel COI para importar sus datos al sistema.</p>
      <form method="POST" action="/importar/upload" enctype="multipart/form-data">
        <div class="mb-3">
          <label class="form-label fw-medium">Archivo FDB</label>
          <input type="file" class="form-control" name="archivo" accept=".fdb" required>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <label class="form-label fw-medium">Año específico (opcional)</label>
            <input type="number" class="form-control" name="year" placeholder="2026" min="2000" max="2100">
            <div class="form-text">Si se deja vacío, importa todos los años disponibles.</div>
          </div>
          <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="limpiar" id="limpiar" value="1">
              <label class="form-check-label" for="limpiar">Limpiar datos existentes antes de importar</label>
            </div>
          </div>
          <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="importarTerceros" id="importarTerceros" value="1" checked>
              <label class="form-check-label" for="importarTerceros">Importar terceros (CTATER)</label>
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-cloud-upload me-1"></i>Importar</button>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
