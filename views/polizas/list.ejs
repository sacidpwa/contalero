<%- include('../partials/header', { title, path }) %>

<div class="container-fluid px-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-journal-text"></i> Pólizas</h4>
    <div class="btn-group">
      <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-plus-lg"></i> Nueva Póliza
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow">
        <li><a class="dropdown-item" href="/polizas/nueva/diario">Tipo <span class="badge bg-primary">I</span> — Ingreso</a></li>
        <li><a class="dropdown-item" href="/polizas/nueva/egreso">Tipo <span class="badge bg-success">E</span> — Egreso</a></li>
        <li><a class="dropdown-item" href="/polizas/nueva/diario">Tipo <span class="badge bg-info">D</span> — Diario</a></li>
        <li><a class="dropdown-item" href="/polizas/nueva/orden">Tipo <span class="badge bg-warning">O</span> — Orden</a></li>
      </ul>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/polizas" class="row g-2 align-items-end">
        <div class="col-auto">
          <label class="form-label small">Mes</label>
          <select class="form-select form-select-sm" name="mes">
            <% for (let m = 1; m <= 12; m++) { %>
              <option value="<%= m %>" <%= (mes == m) ? 'selected' : '' %>><%= m.toString().padStart(2, '0') %></option>
            <% } %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small">Ejercicio</label>
          <select class="form-select form-select-sm" name="ejercicio">
            <% for (let y = 2024; y <= 2030; y++) { %>
              <option value="<%= y %>" <%= (ejercicio == y) ? 'selected' : '' %>><%= y %></option>
            <% } %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small">Tipo</label>
          <select class="form-select form-select-sm" name="tipo">
            <option value="">Todos</option>
            <option value="I" <%= tipo === 'I' ? 'selected' : '' %>>Ingreso</option>
            <option value="E" <%= tipo === 'E' ? 'selected' : '' %>>Egreso</option>
            <option value="D" <%= tipo === 'D' ? 'selected' : '' %>>Diario</option>
            <option value="O" <%= tipo === 'O' ? 'selected' : '' %>>Orden</option>
          </select>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-funnel"></i> Filtrar
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="text-center">Tipo</th>
              <th class="text-center">Número</th>
              <th>Fecha</th>
              <th>Concepto</th>
              <th class="text-end">Total</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (polizas && polizas.length) { %>
              <% polizas.forEach(function(p) { %>
                <% const badgeClass = { I: 'primary', E: 'success', D: 'info', O: 'warning' }[p.tipo] || 'secondary'; %>
                <tr class="cursor-pointer" onclick="window.location='/polizas/<%= p.id %>'" role="button">
                  <td class="text-center">
                    <span class="badge bg-<%= badgeClass %>"><%= p.tipo %></span>
                  </td>
                  <td class="text-center font-monospace"><%= p.numero %></td>
                  <td><%= p.fecha %></td>
                  <td><%= p.concepto %></td>
                  <td class="text-end font-monospace"><%= new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2 }).format(p.total || 0) %></td>
                  <td class="text-center">
                    <a href="/polizas/<%= p.id %>" class="btn btn-sm btn-outline-info me-1" title="Ver">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/polizas/editar/<%= p.id %>" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/polizas/eliminar/<%= p.id %>" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="event.stopPropagation(); return confirm('¿Eliminar la póliza <%= p.tipo %>-<%= p.numero %>?')">
                      <i class="bi bi-trash"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">
                  <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 8px;"></i>
                  No hay pólizas registradas.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
