<%- include('../partials/header', { title, path, mes, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Estado de Resultados</h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">Del 1 al <%= diasMes %> de <%= meses[mes-1] %> de <%= ejercicio %></p>
  </div>
  <form class="d-flex align-items-center gap-2" method="GET" action="/reportes/resultados">
    <div>
      <select class="form-select form-select-sm" name="mes" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var i = 1; i <= 12; i++) { %>
          <option value="<%= i %>" <%= mes == i ? 'selected' : '' %>><%= meses[i-1] %></option>
        <% } %>
      </select>
    </div>
    <div>
      <select class="form-select form-select-sm" name="ejercicio" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var a = 2020; a <= 2035; a++) { %>
          <option value="<%= a %>" <%= ejercicio == a ? 'selected' : '' %>><%= a %></option>
        <% } %>
      </select>
    </div>
    <button type="submit" class="btn btn-sm btn-period"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
  </form>
</div>

<div class="card" style="border:none;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);max-width:700px;margin:0 auto;">
  <div class="card-body p-4">
    <h5 class="text-center fw-bold mb-1" style="color:#0f172a;">Estado de Resultados</h5>
    <p class="text-center text-muted mb-4" style="font-size:.85rem;">Del 1 al <%= diasMes %> de <%= meses[mes-1] %> de <%= ejercicio %></p>

    <table class="table table-borderless mb-0" style="font-size:.9rem;">
      <tbody>
        <tr>
          <td colspan="2" class="fw-bold pb-1 pt-0" style="color:#2563eb;font-size:.95rem;border-bottom:2px solid #2563eb;">
            <i class="bi bi-arrow-up-circle me-1"></i>INGRESOS
          </td>
        </tr>
        <% if (typeof ingresos !== 'undefined' && ingresos.length > 0) { %>
          <% ingresos.forEach(function(c) { %>
            <tr>
              <td class="ps-4 py-1" style="color:#334155;"><%= c.codigo %> — <%= c.nombre %></td>
              <td class="text-end py-1 fw-medium" style="color:#16a34a;">$<%= Number(c.saldo).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            </tr>
          <% }); %>
        <% } %>
        <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
          <td class="pt-2" style="color:#0f172a;">Total Ingresos</td>
          <td class="text-end pt-2" style="color:#16a34a;">$<%= Number(totalIngresos).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>

        <tr>
          <td colspan="2" class="fw-bold pt-4 pb-1" style="color:#dc2626;font-size:.95rem;border-bottom:2px solid #dc2626;">
            <i class="bi bi-arrow-down-circle me-1"></i>COSTOS
          </td>
        </tr>
        <% if (typeof costos !== 'undefined' && costos.length > 0) { %>
          <% costos.forEach(function(c) { %>
            <tr>
              <td class="ps-4 py-1" style="color:#334155;"><%= c.codigo %> — <%= c.nombre %></td>
              <td class="text-end py-1 fw-medium" style="color:#dc2626;">$<%= Number(c.saldo).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            </tr>
          <% }); %>
        <% } %>
        <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
          <td class="pt-2" style="color:#0f172a;">Total Costos</td>
          <td class="text-end pt-2" style="color:#dc2626;">$<%= Number(totalCostos).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>

        <tr class="fw-bold" style="border-top:2px solid #0f172a;">
          <td class="pt-2" style="color:#0f172a;font-size:1rem;">Utilidad Bruta</td>
          <td class="text-end pt-2" style="color:<%= utilidadBruta >= 0 ? '#0f172a' : '#dc2626' %>;font-size:1rem;">$<%= Number(utilidadBruta).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>

        <tr>
          <td colspan="2" class="fw-bold pt-4 pb-1" style="color:#d97706;font-size:.95rem;border-bottom:2px solid #d97706;">
            <i class="bi bi-arrow-down-circle me-1"></i>GASTOS
          </td>
        </tr>
        <% if (typeof gastos !== 'undefined' && gastos.length > 0) { %>
          <% gastos.forEach(function(c) { %>
            <tr>
              <td class="ps-4 py-1" style="color:#334155;"><%= c.codigo %> — <%= c.nombre %></td>
              <td class="text-end py-1 fw-medium" style="color:#d97706;">$<%= Number(c.saldo).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            </tr>
          <% }); %>
        <% } %>
        <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
          <td class="pt-2" style="color:#0f172a;">Total Gastos</td>
          <td class="text-end pt-2" style="color:#d97706;">$<%= Number(totalGastos).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>

        <tr class="fw-bold" style="border-top:2px solid #0f172a;">
          <td class="pt-2" style="color:#0f172a;font-size:1rem;">Utilidad de Operación</td>
          <td class="text-end pt-2" style="color:<%= utilidadOperacion >= 0 ? '#0f172a' : '#dc2626' %>;font-size:1rem;">$<%= Number(utilidadOperacion).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>

        <% if (typeof otrosIngresos !== 'undefined' && otrosIngresos.length > 0) { %>
          <tr>
            <td colspan="2" class="fw-bold pt-4 pb-1" style="color:#059669;font-size:.95rem;border-bottom:2px solid #059669;">
              <i class="bi bi-plus-circle me-1"></i>OTROS INGRESOS
            </td>
          </tr>
          <% otrosIngresos.forEach(function(c) { %>
            <tr>
              <td class="ps-4 py-1" style="color:#334155;"><%= c.codigo %> — <%= c.nombre %></td>
              <td class="text-end py-1 fw-medium" style="color:#059669;">$<%= Number(c.saldo).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
            <td class="pt-2" style="color:#0f172a;">Total Otros Ingresos</td>
            <td class="text-end pt-2" style="color:#059669;">$<%= Number(totalOtrosIngresos).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
          </tr>
        <% } %>

        <% if (typeof otrosGastos !== 'undefined' && otrosGastos.length > 0) { %>
          <tr>
            <td colspan="2" class="fw-bold pt-4 pb-1" style="color:#9333ea;font-size:.95rem;border-bottom:2px solid #9333ea;">
              <i class="bi bi-dash-circle me-1"></i>OTROS GASTOS
            </td>
          </tr>
          <% otrosGastos.forEach(function(c) { %>
            <tr>
              <td class="ps-4 py-1" style="color:#334155;"><%= c.codigo %> — <%= c.nombre %></td>
              <td class="text-end py-1 fw-medium" style="color:#9333ea;">$<%= Number(c.saldo).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
            <td class="pt-2" style="color:#0f172a;">Total Otros Gastos</td>
            <td class="text-end pt-2" style="color:#9333ea;">$<%= Number(totalOtrosGastos).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
          </tr>
        <% } %>

        <tr style="border-top:3px double #0f172a;">
          <td class="pt-3 fw-bold" style="color:#0f172a;font-size:1.15rem;">Utilidad Neta</td>
          <td class="text-end pt-3 fw-bold" style="color:<%= utilidadNeta >= 0 ? '#16a34a' : '#dc2626' %>;font-size:1.15rem;">$<%= Number(utilidadNeta).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>