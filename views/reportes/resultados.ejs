<%- include('../partials/header', { title, path, mes: hasta, ejercicio, empresa }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold" style="color:#0f172a;">Estado de Resultados</h4>
    <p class="text-muted mb-0" style="font-size:.9rem;">
      <% if (desde == 1) { %>
        Del 1 de enero al <%= diasMes %> de <%= meses[hasta-1] %> de <%= ejercicio %>
      <% } else { %>
        Del 1 de <%= meses[desde-1] %> al <%= diasMes %> de <%= meses[hasta-1] %> de <%= ejercicio %>
      <% } %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <a href="/reportes/resultados/formal?ejercicio=<%= ejercicio %>&desde=<%= desde %>&hasta=<%= hasta %>" class="btn btn-outline-dark" target="_blank">
      <i class="bi bi-printer"></i> Formato Imprimible
    </a>
    <form class="d-flex align-items-center gap-2" method="GET" action="/reportes/resultados">
      <select class="form-select form-select-sm" name="desde" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var i = 1; i <= 12; i++) { %>
          <option value="<%= i %>" <%= desde == i ? 'selected' : '' %>><%= meses[i-1] %></option>
        <% } %>
      </select>
      <span class="text-muted small">a</span>
      <select class="form-select form-select-sm" name="hasta" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var i = 1; i <= 12; i++) { %>
          <option value="<%= i %>" <%= hasta == i ? 'selected' : '' %>><%= meses[i-1] %></option>
        <% } %>
      </select>
      <select class="form-select form-select-sm" name="ejercicio" style="border-radius:8px;border-color:#e2e8f0;font-size:.85rem;width:auto;">
        <% for (var a = 2020; a <= 2035; a++) { %>
          <option value="<%= a %>" <%= ejercicio == a ? 'selected' : '' %>><%= a %></option>
        <% } %>
      </select>
      <button type="submit" class="btn btn-sm btn-period"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
    </form>
  </div>
</div>

<div class="card" style="border:none;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered align-middle mb-0" style="font-size:.85rem;">
        <thead class="table-light">
          <tr>
            <th rowspan="2" style="width:40%;">Cuenta</th>
            <th colspan="2" class="text-center" style="border-right:1px solid #dee2e6;">
              <% if (desde == 1) { %>Enero - <%= meses[hasta-1] %><% } else { %><%= meses[desde-1] %> - <%= meses[hasta-1] %><% } %>
            </th>
            <th colspan="2" class="text-center">Acumulado <%= ejercicio %></th>
          </tr>
          <tr>
            <th class="text-end">Importe</th>
            <th class="text-end">%</th>
            <th class="text-end">Importe</th>
            <th class="text-end">%</th>
          </tr>
        </thead>
        <tbody>
          <% function fmt(n) { return Number(n).toLocaleString('es-MX', {minimumFractionDigits:2,maximumFractionDigits:2}); } %>
          <% function pctFmt(n) { return n.toFixed(2) + '%'; } %>

          <!-- INGRESOS -->
          <tr style="background:#eff6ff;">
            <td colspan="5" class="fw-bold" style="color:#2563eb;font-size:.9rem;">INGRESOS</td>
          </tr>
          <% er.ingresos.forEach(function(c) { %>
            <tr>
              <td class="ps-4"><%= c.codigo.replace(/^0+/, '') %> — <%= c.nombre %></td>
              <td class="text-end font-monospace fw-medium">$<%= fmt(c.perVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(c.perPct) %></td>
              <td class="text-end font-monospace fw-medium">$<%= fmt(c.ytdVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(c.ytdPct) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:2px solid #2563eb;">
            <td style="color:#0f172a;">Total Ingresos</td>
            <td class="text-end font-monospace" style="color:#16a34a;">$<%= fmt(er.totalIngresosPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(100) %></td>
            <td class="text-end font-monospace" style="color:#16a34a;">$<%= fmt(er.totalIngresosYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(100) %></td>
          </tr>

          <!-- COSTOS -->
          <tr style="background:#fef2f2;">
            <td colspan="5" class="fw-bold" style="color:#dc2626;font-size:.9rem;">COSTOS</td>
          </tr>
          <% er.costos.forEach(function(c) { %>
            <tr>
              <td class="ps-4"><%= c.codigo.replace(/^0+/, '') %> — <%= c.nombre %></td>
              <td class="text-end font-monospace fw-medium">$<%= fmt(c.perVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(c.perPct) %></td>
              <td class="text-end font-monospace fw-medium">$<%= fmt(c.ytdVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(c.ytdPct) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:2px solid #dc2626;">
            <td style="color:#0f172a;">Total Costos</td>
            <td class="text-end font-monospace" style="color:#dc2626;">$<%= fmt(er.totalCostosPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalCostosPer / er.ventasPer * 100) %></td>
            <td class="text-end font-monospace" style="color:#dc2626;">$<%= fmt(er.totalCostosYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalCostosYTD / er.ventasYTD * 100) %></td>
          </tr>

          <!-- UTILIDAD BRUTA -->
          <tr style="border-top:2px solid #0f172a;background:#f8fafc;">
            <td class="fw-bold" style="font-size:.95rem;">Utilidad Bruta</td>
            <td class="text-end fw-bold font-monospace" style="font-size:.95rem;color:<%= er.utilidadBrutaPer >= 0 ? '#0f172a' : '#dc2626' %>;">$<%= fmt(er.utilidadBrutaPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadBrutaPer / er.ventasPer * 100) %></td>
            <td class="text-end fw-bold font-monospace" style="font-size:.95rem;color:<%= er.utilidadBrutaYTD >= 0 ? '#0f172a' : '#dc2626' %>;">$<%= fmt(er.utilidadBrutaYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadBrutaYTD / er.ventasYTD * 100) %></td>
          </tr>

          <!-- GASTOS DE OPERACIÓN -->
          <tr style="background:#fffbeb;">
            <td colspan="5" class="fw-bold" style="color:#d97706;font-size:.9rem;">GASTOS DE OPERACIÓN</td>
          </tr>
          <% Object.keys(er.gastosOp).forEach(function(key, idx) { %>
            <% var grp = er.gastosOp[key]; %>
            <% var hasMov = grp.some(function(c) { return Math.abs(c.perVal) > 0.01 || Math.abs(c.ytdVal) > 0.01; }); %>
            <% if (!hasMov && key === 'otros') return; %>
            <tr style="cursor:pointer;" onclick="var els=document.querySelectorAll('.gd<%= idx %>');var ic=document.getElementById('iconGasto<%= idx %>');var show=els[0].style.display!='none';els.forEach(function(e){e.style.display=show?'none':'';});ic.className=(show?'bi bi-chevron-right':'bi bi-chevron-down')+' me-1';">
              <td colspan="5" class="fw-semibold ps-3" style="font-size:.85rem;color:#92400e;">
                <i class="bi bi-chevron-down me-1" style="font-size:.7rem;" id="iconGasto<%= idx %>"></i><%= er.gastosOpDef[key].label %>
              </td>
            </tr>
            <% if (hasMov) { %>
              <% grp.forEach(function(c) { %>
                <% if (Math.abs(c.perVal) > 0.01 || Math.abs(c.ytdVal) > 0.01) { %>
                  <tr class="gd<%= idx %>">
                    <td class="ps-5"><%= c.codigo.replace(/^0+/, '') %> — <%= c.nombre %></td>
                    <td class="text-end font-monospace fw-medium">$<%= fmt(c.perVal) %></td>
                    <td class="text-end font-monospace"><%= pctFmt(c.perPct) %></td>
                    <td class="text-end font-monospace fw-medium">$<%= fmt(c.ytdVal) %></td>
                    <td class="text-end font-monospace"><%= pctFmt(c.ytdPct) %></td>
                  </tr>
                <% } %>
              <% }); %>
            <% } %>
            <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
              <td class="ps-4">Total <%= er.gastosOpDef[key].label %></td>
              <td class="text-end font-monospace" style="color:#d97706;">$<%= fmt(er.gastosOpTotals[key].perVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(er.gastosOpTotals[key].perVal / er.ventasPer * 100) %></td>
              <td class="text-end font-monospace" style="color:#d97706;">$<%= fmt(er.gastosOpTotals[key].ytdVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(er.gastosOpTotals[key].ytdVal / er.ventasYTD * 100) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:2px solid #d97706;">
            <td style="color:#0f172a;">Total Gastos de Operación</td>
            <td class="text-end font-monospace" style="color:#d97706;">$<%= fmt(er.totalGastosPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalGastosPer / er.ventasPer * 100) %></td>
            <td class="text-end font-monospace" style="color:#d97706;">$<%= fmt(er.totalGastosYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalGastosYTD / er.ventasYTD * 100) %></td>
          </tr>

          <!-- UTILIDAD OPERACION -->
          <tr style="border-top:2px solid #0f172a;background:#f8fafc;">
            <td class="fw-bold" style="font-size:.95rem;">Utilidad de Operación</td>
            <td class="text-end fw-bold font-monospace" style="font-size:.95rem;color:<%= er.utilidadOperacionPer >= 0 ? '#0f172a' : '#dc2626' %>;">$<%= fmt(er.utilidadOperacionPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadOperacionPer / er.ventasPer * 100) %></td>
            <td class="text-end fw-bold font-monospace" style="font-size:.95rem;color:<%= er.utilidadOperacionYTD >= 0 ? '#0f172a' : '#dc2626' %>;">$<%= fmt(er.utilidadOperacionYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadOperacionYTD / er.ventasYTD * 100) %></td>
          </tr>

          <!-- OTROS INGRESOS Y GASTOS -->
          <tr style="background:#f0fdf4;">
            <td colspan="5" class="fw-bold" style="color:#059669;font-size:.9rem;">OTROS INGRESOS Y GASTOS</td>
          </tr>
          <% var otrasKeys = Object.keys(er.otrosDef); %>
          <% otrasKeys.forEach(function(key, idx) { %>
            <% var grp = er.otrosGrupos[key]; %>
            <% var hasMov = grp.some(function(c) { return Math.abs(c.perVal) > 0.01 || Math.abs(c.ytdVal) > 0.01; }); %>
            <tr style="cursor:pointer;" onclick="var els=document.querySelectorAll('.od<%= idx %>');if(els.length==0)return;var ic=document.getElementById('iconOtro<%= idx %>');var show=els[0].style.display!='none';els.forEach(function(e){e.style.display=show?'none':'';});ic.className=(show?'bi bi-chevron-right':'bi bi-chevron-down')+' me-1';">
              <td colspan="5" class="fw-semibold ps-3" style="font-size:.85rem;color:#065f46;">
                <i class="bi bi-chevron-down me-1" style="font-size:.7rem;" id="iconOtro<%= idx %>"></i><%= er.otrosDef[key].label %>
              </td>
            </tr>
            <% if (hasMov) { %>
              <% grp.forEach(function(c) { %>
                <% if (Math.abs(c.perVal) > 0.01 || Math.abs(c.ytdVal) > 0.01) { %>
                  <tr class="od<%= idx %>">
                    <td class="ps-5"><%= c.codigo.replace(/^0+/, '') %> — <%= c.nombre %></td>
                    <td class="text-end font-monospace fw-medium">$<%= fmt(c.perVal) %></td>
                    <td class="text-end font-monospace"><%= pctFmt(c.perPct) %></td>
                    <td class="text-end font-monospace fw-medium">$<%= fmt(c.ytdVal) %></td>
                    <td class="text-end font-monospace"><%= pctFmt(c.ytdPct) %></td>
                  </tr>
                <% } %>
              <% }); %>
            <% } %>
            <tr class="fw-bold" style="border-top:1px solid #e2e8f0;">
              <td class="ps-4">Total <%= er.otrosDef[key].label %></td>
              <td class="text-end font-monospace" style="color:#059669;">$<%= fmt(er.otrosGrupoTotals[key].perVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(er.otrosGrupoTotals[key].perVal / er.ventasPer * 100) %></td>
              <td class="text-end font-monospace" style="color:#059669;">$<%= fmt(er.otrosGrupoTotals[key].ytdVal) %></td>
              <td class="text-end font-monospace"><%= pctFmt(er.otrosGrupoTotals[key].ytdVal / er.ventasYTD * 100) %></td>
            </tr>
          <% }); %>
          <tr class="fw-bold" style="border-top:1px solid #059669;">
            <td style="color:#0f172a;">Total Otros Ingresos</td>
            <td class="text-end font-monospace" style="color:#059669;">$<%= fmt(er.totalOtrosIngresosPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalOtrosIngresosPer / er.ventasPer * 100) %></td>
            <td class="text-end font-monospace" style="color:#059669;">$<%= fmt(er.totalOtrosIngresosYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalOtrosIngresosYTD / er.ventasYTD * 100) %></td>
          </tr>
          <tr class="fw-bold" style="border-top:1px solid #9333ea;">
            <td style="color:#0f172a;">Total Otros Gastos</td>
            <td class="text-end font-monospace" style="color:#9333ea;">$<%= fmt(er.totalOtrosGastosPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalOtrosGastosPer / er.ventasPer * 100) %></td>
            <td class="text-end font-monospace" style="color:#9333ea;">$<%= fmt(er.totalOtrosGastosYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.totalOtrosGastosYTD / er.ventasYTD * 100) %></td>
          </tr>

          <!-- UTILIDAD NETA -->
          <tr style="border-top:3px double #0f172a;background:#f8fafc;">
            <td class="fw-bold" style="font-size:1.05rem;">Utilidad Neta</td>
            <td class="text-end fw-bold font-monospace" style="font-size:1.05rem;color:<%= er.utilidadNetaPer >= 0 ? '#16a34a' : '#dc2626' %>;">$<%= fmt(er.utilidadNetaPer) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadNetaPer / er.ventasPer * 100) %></td>
            <td class="text-end fw-bold font-monospace" style="font-size:1.05rem;color:<%= er.utilidadNetaYTD >= 0 ? '#16a34a' : '#dc2626' %>;">$<%= fmt(er.utilidadNetaYTD) %></td>
            <td class="text-end font-monospace"><%= pctFmt(er.utilidadNetaYTD / er.ventasYTD * 100) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>